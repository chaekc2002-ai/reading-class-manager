rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 교사 문서: 본인만 읽기/쓰기
    match /teachers/{teacherId} {
      allow read, write: if request.auth != null && request.auth.uid == teacherId;
    }

    // 학급: 학생은 비로그인 상태로 학급 코드 조회 필요 → 읽기는 전체 허용
    // 생성은 인증된 교사만, 수정/삭제는 해당 학급 교사만 허용
    match /classes/{classId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.teacherId == request.auth.uid;
    }

    // 학생: 비로그인 학생도 목록 조회 및 본인 XP/도서 업데이트 필요 → 읽기/쓰기 전체 허용
    // (학생은 Firebase Auth 없이 세션 기반 로그인 사용)
    match /students/{studentId} {
      allow read, write: if true;
    }

    // 타이머: 학생도 타이머 조회 필요 → 읽기는 전체 허용, 쓰기는 인증된 교사만
    match /timers/{classId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 이전 global 컬렉션 (마이그레이션 후 제거 예정)
    match /global/{docId} {
      allow read, write: if true;
    }
  }
}
